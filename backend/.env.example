# Server
PORT=5000

# MongoDB Atlas (optional) — Atlas → Connect → Drivers → copy connection string
# URL-encode special characters in the password (e.g. @ → %40).
# If mongodb+srv fails (DNS), use the "standard" mongodb://… URI from Atlas.
# Optional second URI — connectMongo tries MONGODB_URI first, then MONGODB_URI_FALLBACK.
# MONGODB_URI=
# MONGODB_URI_FALLBACK=
# Database used for app collections (e.g. test_repository). Default: migration_qa
# MONGODB_DB_NAME=migration_qa
# Optional: "4" or "6" to force IP family for Mongo DNS. Omit unless you need the old IPv4-only workaround.
# MONGODB_DNS_FAMILY=
# Lab only: true = skip TLS verify to MongoDB (corporate SSL inspection). Do not use in production.
# MONGODB_TLS_INSECURE=false

# Google OAuth2 (shared client credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google accounts: email=refreshToken (comma-separated pairs)
# Add admins and users — each with their own refresh token
# Format: email1=token1,email2=token2,...
# GmailTestDataAgent uses a *second* account here (when available) as mail To: and calendar attendee;
# messages/events are still created in the migration source mailbox using that user's token.
GOOGLE_ACCOUNTS=admin@domain.com=refresh_token_here,user@domain.com=refresh_token_here

# Microsoft Graph / Azure AD
GRAPH_CLIENT_ID=your_graph_client_id
GRAPH_CLIENT_SECRET=your_graph_client_secret
GRAPH_TENANT_ID=your_graph_tenant_id

# CloudFuze Migration API (no trailing slash; e.g. https://208.70.248.68 or …/proxyservices/v1)
MIGRATION_API_URL=https://devemail.cloudfuze.com/proxyservices/v1
# If POST initiate returns HTTP 405, copy the path from DevTools → Network → initiate (no leading slash).
# Default mail/move/initiate; some servers use mail/initiate
# MIGRATION_API_INITIATE_PATH=mail/initiate
# true = allow self-signed / IP HTTPS (fixes "self-signed certificate" for internal servers). Lab only.
# MIGRATION_API_TLS_INSECURE=true
# Optional: paste Bearer JWT from DevTools → Network → initiate (token only or full "Bearer …"). Skips /mail/login.
# MIGRATION_API_BEARER_TOKEN=
# Base64(email:apiSecret) — OR leave blank if using MIGRATION_API_BASIC_AUTH or MIGRATION_API_BEARER_TOKEN
MIGRATION_API_KEY=your_base64_encoded_credentials
# Optional: Base64(userId:apiSecret) exactly as Email Migration UI sends (DevTools → Network →
# pick an XHR to proxyservices → Headers → Authorization → copy only the string AFTER "Basic ").
# userId is the subscriber id from GET /users/validateUser (field "id"). When set, this overrides MIGRATION_API_KEY for /mail/login.
MIGRATION_API_BASIC_AUTH=
CLOUDFUZE_OWNER_EMAIL=your_admin@cloudfuze.com
# Set true to skip GET /users/validateUser (e.g. browser-session-only or flaky on devemail)
CLOUDFUZE_SKIP_VALIDATE_USER=false
# If false, 5xx from validateUser no longer fails the run; move/initiate still runs after successful /mail/login
# Wait time (ms) after initiating migration before running validation
MIGRATION_WAIT_MS=60000
# Max minutes MigrationAgent polls Outlook for completion (default 30)
MIGRATION_MAX_WAIT_MINUTES=30

# Scheduler
SCHEDULER_ENABLED=false
DEFAULT_SOURCE_EMAIL=source@example.com
DEFAULT_DEST_EMAIL=dest@example.com

# Logging
LOG_LEVEL=info

# Jira + Xray (Server/Data Center REST: /rest/raven/1.0/...). For Jira Cloud + Xray Cloud you may need GraphQL instead.
# JIRA_USER = Server username or Cloud account email. JIRA_API_TOKEN = API token / PAT.
JIRA_BASE_URL=https://your-jira.example.com
JIRA_USER=you@example.com
JIRA_API_TOKEN=your_api_token
# Optional default for POST /api/test-repository/import when projectKey is omitted
JIRA_PROJECT_KEY=TEST
# Optional: pre-fill the Test Repository UI import "Folder path" (Xray path under Test Repository)
# TEST_REPOSITORY_ROOT_PATH=/Box For Business to Dropbox For Business/Selective Versions
# During import, fetch full test steps for offline modal (default true). Set false for faster imports.
# TEST_REPOSITORY_IMPORT_EXPANDED=true
# When expanded data is missing, modal can call live Xray + Jira REST (default true). Set false for strict offline-only
# after Jira is decommissioned — key-only requests use issue id from the saved snapshot, not Jira REST.
# TEST_REPOSITORY_TEST_DETAIL_LIVE_FALLBACK=false
#
# Extra Jira field ids for cached test detail (comma-separated), merged into Xray getExpandedTest jira(fields: [...]).
# Example Cloud Sprint: customfield_10020 — add site-specific custom field ids so they appear under "Additional Jira fields" in the modal.
# JIRA_TEST_DETAIL_JIRA_FIELDS=customfield_10020
#
# Pin the Xray step-level custom field that holds the "Test Steps" (Instruction) text.
# Run: cd backend && npm run debug-test-steps -- TEST-XXXXX  to see the id and name of each step custom field.
# Then set this to the id value shown (e.g. "12345" or "customfield_10042").
# JIRA_XRAY_STEP_TEST_STEPS_CUSTOMFIELD_ID=

# Xray Cloud (required for Test Repository import on atlassian.net — NOT the Jira API token)
# Jira: Settings → Apps → Xray → (gear) Global Settings → API Keys → Create API Key
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
# Optional if your org uses a regional Xray Cloud host
# XRAY_CLOUD_BASE_URL=https://xray.cloud.getxray.app
# Xray GraphQL per-request timeout (ms). Omit or 0 or unlimited = no Axios timeout (waits for Xray; best for huge imports).
# Or set a ceiling, e.g. 3600000 (1 h), max 86400000 (24 h).
# XRAY_GRAPHQL_TIMEOUT_MS=0
#
# Optional: import only a subtree (Xray Cloud path; leading "Test Repository" is stripped if pasted)
# POST /api/test-repository/import body: { "projectKey": "TEST", "rootPath": "/trial/Sanity Cases" }
# CLI: npm run import-test-repository -- TEST "/trial/Sanity Cases"
#
# Full import without browser timeout: cd backend && npm run import-test-repository -- YOUR_PROJECT_KEY
